		<description>A pair of ornamantal shoulder pieces for privates.</description>
		<graphicData>
			<texPath>Things/Apparel/USArmy/OR2/Rank</texPath>
		</graphicData>
		<apparel>
			<wornGraphicPath>Things/Apparel/USArmy/OR2/Rank</wornGraphicPath>
		</apparel>
		<modExtensions Inherit="True">
			<li Class="RocketsRanks.RankExtension">
