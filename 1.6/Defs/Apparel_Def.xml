<?xml version="1.0" encoding="UTF-8"?>
<Defs>
	<ApparelLayerDef>
		<defName>ROCKET_RankLayer</defName>
		<label>rank</label>
		<drawOrder>85</drawOrder>
	</ApparelLayerDef>
	
	<ThingDef ParentName="ApparelMakeableBase" Name="ROCKET_Ranks" Abstract="True">
		<thingClass>RocketsRanks.RocketRank</thingClass>
		<modExtensions>
			<li Class="RocketsRanks.RankRenderExtension">
				<bodyTypes>
					<li>
						<bodyType>Male</bodyType>
						<northOffsetX>0</northOffsetX>
						<northOffsetZ>0.183</northOffsetZ>
						<northScale>1.35</northScale>
						<eastOffsetX>-0.0614</eastOffsetX>
						<eastOffsetZ>0.1579</eastOffsetZ>
						<eastScale>0.8701</eastScale>
					</li>
					<li>
						<bodyType>Female</bodyType>
						<northOffsetZ>0.1625</northOffsetZ>
						<northScale>1.1837</northScale>
						<eastOffsetX>0.0477</eastOffsetX>
						<eastOffsetZ>0.1275</eastOffsetZ>
						<eastScale>0.6842</eastScale>
					</li>
					<li>
						<bodyType>Thin</bodyType>
						<northOffsetX>0.00115</northOffsetX>
						<northOffsetZ>0.1441</northOffsetZ>
						<northScale>0.8285</northScale>
						<eastOffsetX>-0.0603</eastOffsetX>
						<eastOffsetZ>0.1309</eastOffsetZ>
						<eastScale>0.7258</eastScale>
					</li>
					<li>
						<bodyType>Fat</bodyType>
						<northOffsetZ>0.1906</northOffsetZ>
						<northScale>1.9052</northScale>
						<eastOffsetX>-0.089</eastOffsetX>
						<eastOffsetZ>0.0993</eastOffsetZ>
						<eastScale>0.8118</eastScale>
					</li>
					<li>
						<bodyType>Hulk</bodyType>
						<northOffsetZ>0.247</northOffsetZ>
						<northScale>1.96</northScale>
						<eastOffsetX>-0.0683</eastOffsetX>
						<eastOffsetZ>0.0861</eastOffsetZ>
						<eastScale>0.834</eastScale>
					</li>
				</bodyTypes>
			</li>
		</modExtensions>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
			<drawSize>0.75</drawSize>
		</graphicData>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<WorkToMake>1500</WorkToMake>
			<Mass>0.1</Mass>
			<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
			<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
			<EquipDelay>1.5</EquipDelay>
		</statBases>
		<costStuffCount>10</costStuffCount>
		<costList>
			<Gold>1</Gold>
		</costList>
		<stuffCategories>
			<li>Fabric</li>
			<li>Leathery</li>
			<li>Metallic</li>
		</stuffCategories>
		<apparel>
			<countsAsClothingForNudity>false</countsAsClothingForNudity>
			<layers>
				<li>ROCKET_RankLayer</li>
			</layers>
			<useWornGraphicMask>true</useWornGraphicMask>
			<bodyPartGroups>
				<li>Shoulders</li>
			</bodyPartGroups>
			<tags>
				<li>RankInsignia</li>
			</tags>
			<defaultOutfitTags>
				<li>Soldier</li>
				<li>Nudist</li>
			</defaultOutfitTags>
		</apparel>
	</ThingDef>
	
	<ThingDef ParentName="ROCKET_Ranks" Name="ROCKET_Ranks_Enlisted" Abstract="True">	
