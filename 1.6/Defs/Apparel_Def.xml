			<SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">-0.05</SlaveSuppressionOffset>
			<MentalBreakThreshold>-0.05</MentalBreakThreshold>
		</equippedStatOffsets>
		<uiOrder>1</uiOrder>
	</ThingDef>
	
